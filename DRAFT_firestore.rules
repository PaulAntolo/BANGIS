rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Rules ---
    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.email is string && data.email.size() <= 256
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1000))
        && (data.rank == null || (data.rank is string && data.rank.size() <= 50))
        && (data.contributionCount == null || data.contributionCount is int);
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) 
        && incoming().keys().hasAll(['uid', 'email', 'createdAt'])
        && incoming().keys().size() >= 3
        && isValidUser(incoming()) 
        && incoming().createdAt == request.time;
      allow update: if isOwner(userId) 
        && isValidUser(incoming()) 
        && incoming().createdAt == existing().createdAt
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'rank', 'contributionCount'])
        );
    }

    // --- Station Rules ---
    function isValidStation(data) {
      return data.name is string && data.name.size() <= 100
        && data.brand is string && data.brand.size() <= 50
        && data.address is string && data.address.size() <= 256;
    }

    match /stations/{stationId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --- PriceReport Rules ---
    function isValidPriceReport(data) {
      return isValidId(data.stationId)
        && data.userId == request.auth.uid
        && data.fuelType in ['diesel', 'unleaded', 'premium']
        && data.price is number && data.price > 0 && data.price < 1000
        && (data.reportType == null || data.reportType in ['low', 'normal', 'high'])
        && (data.details == null || (data.details is string && data.details.size() <= 1000));
    }

    match /priceReports/{reportId} {
      allow read: if true;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid; // Secure list
      allow create: if isSignedIn() && isEmailVerified() 
        && incoming().keys().hasAll(['stationId', 'userId', 'fuelType', 'price', 'createdAt'])
        && isValidPriceReport(incoming()) 
        && incoming().createdAt == request.time;
      allow update: if (isOwner(existing().userId) || isAdmin()) 
        && isValidPriceReport(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['price', 'fuelType', 'reportType', 'details', 'imageUrl']);
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    // --- Activity Rules ---
    match /activities/{activityId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
